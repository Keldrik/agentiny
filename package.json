{
  "name": "agentiny",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "oxlint packages",
    "format": "oxfmt --check \"{packages,examples}/**/*.{ts,tsx,js,json,md}\"",
    "format:write": "oxfmt --write \"{packages,examples}/**/*.{ts,tsx,js,json,md}\"",
    "demo": "npm run build -w @agentiny/core && node examples/triggers-demo.mjs"
  },
  "devDependencies": {
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "tsup": "^8.5.1"
  }
}
